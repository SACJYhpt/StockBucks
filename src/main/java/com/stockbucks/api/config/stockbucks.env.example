# ============================================================
# StockBucks API 設定範例
# 請複製成專案根目錄的 .env 或 stockbucks.env。
# 不要把真正的 API Key、帳號、密碼提交到 Git。
#
# 讀取順序：
# 1. Java system property
# 2. 作業系統環境變數
# 3. 專案根目錄 .env
# 4. 專案根目錄 stockbucks.env
# 5. 使用者家目錄 ~/.stockbucks/.env
#
# 大多數變數也支援 STOCKBUCKS_ 前綴版本，
# 例如 FUGLE_API_KEY 也可寫成 STOCKBUCKS_FUGLE_API_KEY。
# ============================================================

# ----------------------------
# AI API 設定
# ----------------------------
# 可選值：
# gemini、anthropic、openrouter、ollama、openai-compatible、openai
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Gemini / Google
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Anthropic / Claude
ANTHROPIC_API_KEY=
ANTHROPIC_VERSION=2023-06-01

# OpenRouter
OPENROUTER_API_KEY=

# OpenAI
OPENAI_API_KEY=

# OpenAI-compatible 服務共用 Key，例如本地或第三方相容服務
AI_API_KEY=

# Ollama 本機服務；不需要 API Key。
# OLLAMA_MODEL 建議使用 StockBucks 建立的繁體中文模型，避免簡體字輸出。
# 如果 OLLAMA_EXE_PATH / OLLAMA_MODELS 不填，程式會嘗試使用：
# ../ai/tools/ollama/ollama.exe
# ../ai/data/ollama_models
# 注意：Ollama 不共用 AI_MODEL / AI_BASE_URL，避免其他 AI provider 的設定互相污染。
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=stockbucks-traditional-zh:latest
OLLAMA_EXE_PATH=
OLLAMA_MODELS=

# 常見 AI_PROVIDER 搭配：
# gemini            -> GEMINI_API_KEY=... AI_MODEL=gemini-2.5-flash
# anthropic         -> ANTHROPIC_API_KEY=... AI_MODEL=claude-sonnet-4-5-20250929
# openrouter        -> OPENROUTER_API_KEY=... AI_MODEL=anthropic/claude-sonnet-4.5
# ollama            -> OLLAMA_BASE_URL=http://localhost:11434 OLLAMA_MODEL=stockbucks-traditional-zh:latest
# openai-compatible -> AI_BASE_URL=http://localhost:8000/v1 AI_API_KEY=... AI_MODEL=your-model
# openai            -> OPENAI_API_KEY=... AI_MODEL=gpt-4.1-mini

# ----------------------------
# 股票資料來源排序
# ----------------------------
# 第一個可用來源會勝出；如果缺設定、抓不到資料或失敗，才會往下一個來源。
# 目前依「最小時間單位」排序：
# 券商日內資料 -> Fugle 盤中報價 -> 網頁近即時報價 -> TWSE 日資料 -> FinMind 日資料 -> 本地 CSV
STOCK_PROVIDER_CHAIN=broker,fugle,web,twse,finmind,local

# 歷史資料來源順序：TWSE 官方日資料打底，web / FinMind / local 補缺日期。
STOCK_HISTORY_PROVIDER_CHAIN=twse,web,finmind,local

# ----------------------------
# 券商帳戶 / 券商 API
# ----------------------------
# 目前是查詢用途：報價、日內 K 線、帳戶總覽、庫存。
# 不要把真實券商帳密提交到 Git。
BROKER_PROVIDER=generic-http
BROKER_BASE_URL=
BROKER_USERNAME=
BROKER_PASSWORD=
BROKER_API_KEY=
BROKER_AUTH_TOKEN=
BROKER_AUTH_TOKEN_FIELD=token
BROKER_CERT_PATH=
BROKER_CERT_PASSWORD=

# 端點模板依券商不同而不同。
# 支援替換：{symbol}、{stockId}、{interval}
BROKER_LOGIN_ENDPOINT=
BROKER_QUOTE_ENDPOINT=
BROKER_INTRADAY_BARS_ENDPOINT=
BROKER_ACCOUNT_ENDPOINT=
BROKER_POSITIONS_ENDPOINT=

# ----------------------------
# Fugle 股票資料
# ----------------------------
# Fugle 可提供較接近盤中的 intraday quote。
FUGLE_API_KEY=
FUGLE_BASE_URL=https://api.fugle.tw/marketdata/v1.0/stock

# ----------------------------
# TWSE 公開資料
# ----------------------------
# 主要用於 TWSE 公開日資料與上市股票資料。
TWSE_WEB_BASE_URL=https://www.twse.com.tw
TWSE_OPENAPI_BASE_URL=https://openapi.twse.com.tw/v1

# ----------------------------
# 網路爬蟲股票資料
# ----------------------------
# 只讀公開頁面；不處理登入、驗證碼、付費牆或封鎖內容。
# 可調整順序，例如 yahoo,google,cnbc,wantgoo,msn。
WEB_STOCK_SOURCES=google,yahoo,cnbc,msn,wantgoo
WEB_STOCK_GOOGLE_URL_TEMPLATE=https://www.google.com/finance/quote/%s:TPE?hl=zh-TW
WEB_STOCK_YAHOO_URL_TEMPLATE=https://tw.stock.yahoo.com/quote/%s.TW
WEB_STOCK_YAHOO_CHART_URL_TEMPLATE=https://query1.finance.yahoo.com/v8/finance/chart/%s.TW?period1=%d&period2=%d&interval=1d
WEB_STOCK_CNBC_URL_TEMPLATE=https://www.cnbc.com/quotes/%s.TW
WEB_STOCK_MSN_URL_TEMPLATE=
WEB_STOCK_WANTGOO_URL_TEMPLATE=https://www.wantgoo.com/stock/%s
WEB_STOCK_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/125 Safari/537.36 StockBucks/1.0

# ----------------------------
# FinMind 股票資料
# ----------------------------
# 目前主要用於 TaiwanStockPrice 日資料備援。
FINMIND_TOKEN=
FINMIND_BASE_URL=https://api.finmindtrade.com/api/v4/data

# ----------------------------
# 本地 CSV 備援
# ----------------------------
# CsvLoading 目前會讀 data/{LOCAL_STOCK_CSV_NAME}.csv。
LOCAL_STOCK_CSV_NAME=TestDataTSMC
